# HTTP port used by the Echo backend server.
APP_PORT=1323

# Controls whether internal error details are exposed. Use FALSE outside local development.
SHOW_ERR_MODE=FALSE

# PostgreSQL connection URL used by the backend and migration commands.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/app?sslmode=disable

# Secret used to sign JWT access tokens. Replace with a long, random value.
JWT_SECRET=replace-with-a-long-random-secret

# JWT expiration duration in minutes.
JWT_EXPIRATION=15

# AES key used to encrypt and decrypt API values. Must be exactly 16, 24, or 32 bytes.
CRYPTO_KEY=replace-with-a-32-byte-aes-key!!

# Optional auth user UUID that bypasses per-endpoint access checks and receives bootstrap API contracts.
# Leave empty when no bootstrap user is required.
AUTH_ACCESS_BOOTSTRAP_USER_ID=

# Firebase project ID used to initialize the Firebase Cloud Messaging provider.
FCM_SERVICE_ACCOUNT_ID=your-firebase-project-id

# Absolute path to a Firebase service-account JSON file used by Google default credential discovery.
# Keep the credential file outside the repository and never commit its contents.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json
